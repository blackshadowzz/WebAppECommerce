@model List<Category>

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
}

@if (TempData["Message"] != null)
{
    <h4>@TempData["Message"]</h4>
}
<h1>Create</h1>

<table class="table">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Description</th>
        <th>Action</th>
    </tr>
    @for(int i = 0; i < Model.Count(); i++)
    {
        <tr>
            <td>@Model[i].Id</td>
            <td>@Model[i].CategoryName</td>
            <td>@Model[i].Description</td>
            <td>

            </td>
        </tr>
    }
</table>